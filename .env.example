# Copy this file to .env before running Docker Compose.

# Database
DB_HOST=db
DB_PORT=3306
DB_HOST_PORT=3307
DB_USER=root
DB_PASSWORD=rootpassword
DB_NAME=gdelt

# App ports
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Forecast model included in this branch
THP_CHECKPOINT_PATH=models/thp_gdelt.pt

# Optional ChromaDB path for chat RAG. Forecast does not require ChromaDB.
CHROMA_DB_PATH=/app/chroma_db

# Optional LLM settings for Analyst Chat.
# Forecast and Dashboard can run without an LLM key.
LLM_PROVIDER=kimi_code
LLM_BASE_URL=https://api.kimi.com/coding/v1
LLM_MODEL=kimi-k2-0905-preview
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
KIMI_CODE_API_KEY=replace_with_your_key
