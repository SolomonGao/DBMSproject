# ================================================
# Python
# ================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
venv/
.venv/
ENV/
env/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
tmp/

# ================================================
# Project Specific
# ================================================
# Data files (GDELT CSV files)
data/*
!data/.gitkeep

# Environment variables (API keys, passwords)
.env
.env.*
!.env.example

# Logs
logs/*
!logs/.gitkeep

# Agent documentation (auto-generated)
AGENTS.md

# Local test files
test_*.py
*_test.py
# 忽略 ChromaDB 向量数据库文件夹
chroma_db/

# 忽略本地同步进度文件
db_scripts/sync_progress.txt

node_modules/
frontend/node_modules/
frontend/dist/

# Local model artifacts.
# Keep only the final lightweight THP checkpoint needed by Forecast.
*.pt
*.pth
*.onnx
*.safetensors
*.npz
models/*
!models/
!models/thp_gdelt.pt
!models/README.md

# Local databases, dumps, and vector stores
*.db
*.sqlite
*.sqlite3
*.duckdb
*.sql.gz
*.dump

secrets/*
!secrets/README.md
