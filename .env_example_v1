# GDELT MCP Client App v1 配置
# 复制此文件为 .env 并填写您的配置
# 或使用: python run_v1.py --config 进行交互式配置

# ============================================
# 必填配置: LLM 提供商
# ============================================

# LLM 提供商: kimi_code, moonshot, claude, 或 gemini
LLM_PROVIDER=kimi_code

# 根据提供商选择对应 API Key:

# 1) Kimi Code (推荐) - 支持搜索和抓取服务
# API 地址: https://api.kimi.com/coding/v1
KIMI_CODE_API_KEY=your_kimi_code_api_key_here

# 2) Moonshot AI (Open Platform) - https://platform.moonshot.cn/
# MOONSHOT_API_KEY=your_moonshot_api_key_here

# 3) Claude (Anthropic) - https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 4) Gemini (Google) - https://ai.google.dev/
# GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# 可选配置（一般使用默认值即可）
# ============================================

# MCP Server 路径（留空则自动检测）
# MCP_SERVER_PATH=C:/path/to/mcp_server/server.py

# 传输模式: stdio 或 sse
MCP_TRANSPORT=stdio

# SSE 模式端口（仅 transport=sse 时有效）
MCP_PORT=8000

# LLM 模型（留空使用提供商默认）
# Kimi: kimi-k2-0905-preview, kimi-k2-0711-preview, kimi-k1.5-0711-preview
# Claude: claude-3-5-sonnet-20241022, claude-3-5-haiku, claude-3-opus
# Gemini: gemini-1.5-pro, gemini-1.5-flash
LLM_MODEL=kimi-k2-0905-preview

# LLM API 地址（留空使用提供商默认）
# LLM_BASE_URL=https://api.kimi.com/coding/v1

# LLM 温度参数 (0.0 - 1.0)
LLM_TEMPERATURE=0.7

# 最大 Token 数
LLM_MAX_TOKENS=4096

# ============================================
# 日志配置
# ============================================

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 是否写入文件日志
LOG_TO_FILE=true

# ============================================
# 开发配置
# ============================================

# 调试模式
DEBUG=false
